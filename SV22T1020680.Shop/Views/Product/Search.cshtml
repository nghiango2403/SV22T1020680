@model PagedResult<Product>
@{
}

<div class="mb-3">
    <p class="text-muted">
        Tìm thấy <b>@Model.RowCount</b> mặt hàng trong tổng số <b>@Model.PageCount</b> trang.
    </p>
</div>

<div class="row g-4">
    @foreach (var item in Model.DataItems)
    {
        <div class="col-12 col-sm-6 col-md-4 col-lg-3">
            <div class="card h-100 border-0 shadow-sm product-card transition-up">
                <div class="position-relative overflow-hidden" style="height: 200px;">
                    <img src="@(string.IsNullOrEmpty(item.Photo) ? "/images/products/no-image.png" : "/images/products/" + item.Photo)"
                         class="card-img-top w-100 h-100 object-fit-cover"
                         alt="@item.ProductName">
                </div>

                <div class="card-body p-3">
                    <h6 class="card-title fw-bold text-dark text-truncate-2 mb-2">@item.ProductName</h6>
                    <p class="text-muted small mb-1">Đơn vị: @item.Unit</p>
                    <div class="d-flex align-items-center justify-content-between">
                        <span class="text-primary fw-bold fs-5">@item.Price.ToString("N0") đ</span>
                    </div>
                </div>

                <div class="card-footer bg-transparent border-0 p-3 pt-0">
                    <div class="d-grid gap-2">
                        <button type="button"
                                class="btn btn-primary btn-sm fw-bold rounded-pill"
                                onclick="addToCart(@item.ProductID)">
                            <i class="fa-solid fa-cart-plus me-1"></i> Thêm vào giỏ hàng
                        </button>

                        <a href="/Product/Detail/@item.ProductID" class="btn btn-outline-secondary btn-sm rounded-pill fw-bold">
                            Chi tiết
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@if (Model.PageCount > 1)
{
    var baseRoute = new Dictionary<string, string>
    {
        { "SearchValue", ViewBag.Input?.SearchValue ?? "" },
        { "PageSize", (ViewBag.Input?.PageSize ?? 12).ToString() },
        { "CategoryID", (ViewBag.Input?.CategoryID ?? 0).ToString() },
        { "SupplierID", (ViewBag.Input?.SupplierID ?? 0).ToString() },
        { "MinPrice", (ViewBag.Input?.MinPrice ?? 0).ToString() },
        { "MaxPrice", (ViewBag.Input?.MaxPrice ?? 0).ToString() }
    };

    <div class="card-footer bg-white border-top-0 pt-4 pb-3">
        <nav aria-label="Page navigation">
            <ul class="pagination justify-content-center mb-0 shadow-sm rounded">

                @* Nút Quay lại *@
                @{ baseRoute["Page"] = (Model.Page - 1).ToString(); }
                <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                    <a class="page-link border-0 rounded-start px-3"
                       asp-controller="Product" asp-action="Search" asp-all-route-data="baseRoute">
                        <i class="fa-solid fa-angle-left"></i>
                    </a>
                </li>

                @* Danh sách các trang *@
                @foreach (var pageItem in Model.GetDisplayPages())
                {
                    if (pageItem.IsCurrent)
                    {
                        <li class="page-item active" aria-current="page">
                            <span class="page-link border-0 fw-bold">@pageItem.Page</span>
                        </li>
                    }
                    else if (pageItem.IsEllipsis)
                    {
                        <li class="page-item disabled">
                            <span class="page-link border-0 bg-light">...</span>
                        </li>
                    }
                    else
                    {
                        baseRoute["Page"] = pageItem.Page.ToString();
                        <li class="page-item">
                            <a class="page-link border-0 text-dark"
                               asp-controller="Product" asp-action="Search" asp-all-route-data="baseRoute">
                                @pageItem.Page
                            </a>
                        </li>
                    }
                }

                @* Nút Tiếp theo *@
                @{ baseRoute["Page"] = (Model.Page + 1).ToString(); }
                <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                    <a class="page-link border-0 rounded-end px-3"
                       asp-controller="Product" asp-action="Search" asp-all-route-data="baseRoute">
                        <i class="fa-solid fa-angle-right"></i>
                    </a>
                </li>

            </ul>
        </nav>
    </div>
}
<style>
    .product-card {
        border-radius: 12px;
        transition: all 0.3s ease;
    }

    .transition-up:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 15px rgba(0,0,0,0.1) !important;
    }

    /* Overlay hiệu ứng xem nhanh */
    .product-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0,0,0,0.2);
        opacity: 0;
        transition: opacity 0.3s ease;
    }

    .product-card:hover .product-overlay {
        opacity: 1;
    }

    .text-truncate-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        min-height: 40px;
    }

    .pagination .page-link {
        transition: all 0.2s ease;
        color: #495057;
        margin: 0 2px;
        border-radius: 8px !important; /* Bo góc nhẹ cho từng nút */
    }

    .pagination .page-item.active .page-link {
        background-color: #0d6efd; /* Màu xanh Primary */
        box-shadow: 0 4px 10px rgba(13, 110, 253, 0.3);
    }

    .pagination .page-link:hover:not(.active) {
        background-color: #f8f9fa;
        color: #0d6efd;
        transform: translateY(-1px);
    }
</style>
