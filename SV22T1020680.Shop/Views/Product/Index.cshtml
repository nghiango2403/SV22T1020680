@model Dictionary<int, List<Product>>

<div class="container py-4">
    @foreach (var category in Model)
    {
        <div class="d-flex align-items-center justify-content-between mb-4 mt-5">
            <h3 class="fw-bold text-uppercase border-start border-4 border-primary ps-3">
                @if (category.Key == 1)
                {
                    <text>May mặc</text>
                }
                else if (category.Key == 2)
                {

                    <text>Mỹ phẩm</text>
                }
                else
                {

                    <text>Điện tử</text>
                }
            </h3>
            <a href="/Product/Search?CategoryID=@category.Key" class="text-decoration-none shadow-sm btn btn-outline-primary btn-sm rounded-pill px-3">
                Xem tất cả <i class="fa-solid fa-arrow-right ms-1"></i>
            </a>
        </div>

        <div class="row g-4">
            @foreach (var item in category.Value)
            {
                <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                    <div class="card h-100 border-0 shadow-sm product-card transition-up">
                        <div class="position-relative overflow-hidden" style="height: 200px;">
                            <img src="@(string.IsNullOrEmpty(item.Photo) ? "/images/products/nophoto.png" : "/images/products/" + item.Photo)"
                                 class="card-img-top w-100 h-100 object-fit-cover shadow-inner"
                                 alt="@item.ProductName">
                            @if (!item.IsSelling)
                            {
                                <span class="badge bg-danger position-absolute top-0 end-0 m-2">Hết hàng</span>
                            }
                        </div>

                        <div class="card-body d-flex flex-column p-3">
                            <h6 class="card-title fw-bold text-dark text-truncate-2 mb-2" style="height: 40px;">
                                @item.ProductName
                            </h6>
                            <div class="mt-auto">
                                <p class="text-muted small mb-1">Đơn vị: <span class="fw-medium text-dark">@item.Unit</span></p>
                                <div class="d-flex align-items-center justify-content-between">
                                    <span class="text-primary fw-bold fs-5">@item.Price.ToString("N0") <small>đ</small></span>
                                </div>
                            </div>
                        </div>
                                            
                        <div class="card-footer bg-transparent border-0 p-3 pt-0">
                            <div class="d-grid gap-2">
                                <button type="button"
                                        class="btn btn-primary btn-sm fw-bold rounded-pill"
                                        onclick="addToCart(@item.ProductID)">
                                    <i class="fa-solid fa-cart-plus me-1"></i> Thêm vào giỏ hàng
                                </button>

                                <a href="/Product/Detail/@item.ProductID" class="btn btn-outline-secondary btn-sm rounded-pill fw-bold">
                                    Chi tiết
                                </a>
                            </div>
                        </div>
                        
                    </div>
                </div>
            }
        </div>
    }
</div>

@section Styles {
    <style>
        .product-card {
            border-radius: 15px;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

        .transition-up:hover {
            transform: translateY(-8px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.12) !important;
        }

        .text-truncate-2 {
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .object-fit-cover {
            object-fit: cover;
        }

        .shadow-inner {
            box-shadow: inset 0 0 10px rgba(0,0,0,0.05);
        }
    </style>
}