@model ProductSearchInput
@using SV22T1020680.Shop.AppCodes
@{
    var userData = User.GetUserData();
}
<header class="navbar navbar-expand-lg navbar-light bg-white sticky-top shadow-sm" style="z-index: 1050;">
    <div class="container">
        <a class="navbar-brand d-flex align-items-center fw-bold text-primary" href="/">
            <i class="fa-solid fa-bolt-lightning me-2 fs-3"></i>
            <span style="letter-spacing: -1px;">LITECOMMERCE</span>
        </a>


        <div class="mx-lg-5 flex-grow-1 d-none d-md-block">
            <form action="/Product/Search" method="GET" id="mainSearchForm">
                <div class="input-group shadow-sm" style="border-radius: 12px; border: 1px solid #dee2e6; overflow: visible;">

                    <div style="width: 190px;">
                        <input type="hidden" asp-for="PageSize" value="12"/>
                        <input type="hidden" asp-for="Page" value="1" />
                        <input type="hidden" asp-for="SupplierID" value="0">
                        <select class="form-select border-0 border-end py-2 px-3 fw-medium text-muted rounded-0 shadow-none h-100"
                                asp-for="CategoryID" style="background-color: #f8f9fa;" asp-items="await SelectListHelper.Categories()">
                        </select>
                    </div>
                    <input type="text" asp-for="SearchValue" class="form-control border-0 py-2 ps-3 shadow-none"
                           placeholder="Tìm sản phẩm..." style="min-width: 150px;">

                    <div class="dropdown">
                        <button class="btn btn-light dropdown-toggle border-0 border-start py-2 px-3 fw-medium text-muted rounded-0 shadow-none h-100"
                                type="button" id="priceRangeBtn" data-bs-toggle="dropdown" data-bs-auto-close="outside">
                            <span id="priceRangeLabel">
                                @if (Model.MinPrice > 0 && Model.MaxPrice > 0)
                                {
                                    @($"{Model.MinPrice:N0} - {Model.MaxPrice:N0} VNĐ")
                                }
                                else if (Model.MinPrice > 0)
                                {
                                    @($"Từ {Model.MinPrice:N0} VNĐ")
                                }
                                else if (Model.MaxPrice > 0)
                                {
                                    @($"Đến {Model.MaxPrice:N0} VNĐ")
                                }
                                else
                                {
                                    @:Khoảng giá
                                }
                            </span>
                        </button>
                        
                        <div class="dropdown-menu p-3 shadow-lg border-0 mt-2" style="width: 300px;">
                            <h6 class="dropdown-header px-0 mb-2 text-dark fw-bold">Khoảng giá (VNĐ)</h6>
                            <div class="row g-2 align-items-center">
                                <div class="col-12">
                                    <div id="priceErrorMessage" class="text-danger small mb-2 d-none">
                                        * Giá "Từ" phải nhỏ hơn hoặc bằng giá "Đến"
                                    </div>
                                </div>
                                <input type="hidden" id="realMinPrice" name="MinPrice" value="@Model.MinPrice" />
                                <input type="hidden" id="realMaxPrice" name="MaxPrice" value="@Model.MaxPrice" />
                                <input type="number" id="tempMinPrice"
                                       value="@(Model.MinPrice > 0 ? Model.MinPrice.ToString() : "")"
                                       class="form-control form-control-sm" placeholder="Từ">

                                <input type="number" id="tempMaxPrice"
                                       value="@(Model.MaxPrice > 0 ? Model.MaxPrice.ToString() : "")"
                                       class="form-control form-control-sm" placeholder="Đến">
                            </div>
                            <div class="mt-3 text-end border-top pt-2">
                                <button type="button" id="applyPriceBtn" class="btn btn-primary btn-sm px-3 fw-bold">Xác nhận</button>
                            </div>
                        </div>
                    </div>

                    <button class="btn btn-primary px-4 border-0 rounded-0" type="submit">
                        <i class="fa-solid fa-magnifying-glass"></i>
                    </button>
                </div>
            </form>
        </div>

        <div class="d-flex align-items-center gap-2">
            <button class="btn d-md-none nav-icon-btn border-0 shadow-none">
                <i class="fa-solid fa-magnifying-glass"></i>
            </button>

            <a href="/Order/Create" class="nav-icon-btn text-dark text-decoration-none position-relative">
                <i class="fa-solid fa-cart-shopping fs-5"></i>
                @{
                    int itemCount = ShoppingCartService.GetCartItemCount();
                    // Lấy danh sách ID sản phẩm hiện có trong giỏ hàng để JS biết
                    var currentProductIds = ShoppingCartService.GetShoppingCart().Select(x => x.ProductID).ToList();
                }

                <script>
                    window.currentCartProductIds = @Html.Raw(Json.Serialize(currentProductIds));
                </script>
                <span id="cart-count" class="position-absolute translate-middle badge rounded-pill bg-danger @(itemCount > 0 ? "" : "d-none")" style="top: 3px; right: -10px;">
                    @itemCount
                </span>
            </a>

            @if (userData != null)
            {
                <div class="dropdown">
                    <button class="btn nav-icon-btn border-0 p-0 shadow-none" data-bs-toggle="dropdown">
                            <i class="fa-solid fa-circle-user fs-4"></i>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end mt-3 p-2 shadow border-0">
                        <li>
                            <div class="dropdown-header fw-bold text-dark border-bottom mb-2 pb-2">
                                Chào, @userData.DisplayName
                            </div>
                        </li>
                        <li><a class="dropdown-item rounded-2 py-2" href="/Customer"><i class="fa-regular fa-user me-2"></i>Thông tin cá nhân</a></li>
                        <li><a class="dropdown-item rounded-2 py-2" href="/Order"><i class="fa-solid fa-clock-rotate-left me-2"></i>Lịch sử mua hàng</a></li>
                        <li><a class="dropdown-item rounded-2 py-2" href="/Account/ChangePassword"><i class="fa-solid fa-shield-halved me-2"></i>Đổi mật khẩu</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item rounded-2 py-2 text-danger fw-bold" href="/Account/Logout"><i class="fa-solid fa-right-from-bracket me-2"></i>Đăng xuất</a></li>
                    </ul>
                </div>
            }
            else
            {
                <a href="/Account/Login" class="btn btn-outline-primary btn-sm px-3 fw-bold rounded-pill">
                    ĐĂNG NHẬP
                </a>
            }
        </div>
    </div>
</header>
<script>
        document.getElementById('applyPriceBtn').addEventListener('click', function () {
        const minVal = document.getElementById('tempMinPrice').value;
        const maxVal = document.getElementById('tempMaxPrice').value;
        const label = document.getElementById('priceRangeLabel');
        const errorMsg = document.getElementById('priceErrorMessage');

        const minPrice = minVal ? parseFloat(minVal) : 0;
        const maxPrice = maxVal ? parseFloat(maxVal) : 0;

        // 1. Kiểm tra logic
        if (minVal && maxVal && minPrice > maxPrice) {
            if (errorMsg) errorMsg.classList.remove('d-none');
            return;
        }

        // 2. CẬP NHẬT GIÁ TRỊ VÀO INPUT ẨN (Quan trọng nhất)
        document.getElementById('realMinPrice').value = minVal;
        document.getElementById('realMaxPrice').value = maxVal;

        // 3. Cập nhật nhãn hiển thị (như cũ)
        if (minVal && maxVal) {
            label.innerText = `${minPrice.toLocaleString()} - ${maxPrice.toLocaleString()} VNĐ`;
        } else if (minVal) {
            label.innerText = `Từ ${minPrice.toLocaleString()} VNĐ`;
        } else if (maxVal) {
            label.innerText = `Đến ${maxPrice.toLocaleString()} VNĐ`;
        } else {
            label.innerText = "Khoảng giá";
        }

        // 4. Đóng dropdown
        const dropdownElement = document.getElementById('priceRangeBtn');
        const dropdown = bootstrap.Dropdown.getInstance(dropdownElement);
        if (dropdown) dropdown.hide();
    });
</script>