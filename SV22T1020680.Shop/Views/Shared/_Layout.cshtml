<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>LiteCommerce - Hệ thống mua sắm hiện đại</title>
    <link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/lib/font_awesome/css/all.min.css" rel="stylesheet" />
    <link href="~/css/site.css" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/flatpickr/flatpickr.min.css">
    @await RenderSectionAsync("Styles", required: false)

</head>
<body>

@using SV22T1020680.Shop.AppCodes
@using SV22T1020680.Models.Catalog
@{
    var searchInput = ApplicationContext.GetSessionData<ProductSearchInput>("ProductSearchInput") 
                     ?? new ProductSearchInput { Page = 1, PageSize = 12, SearchValue = "" };
}
    @await Html.PartialAsync("_Header", searchInput)

    <div class="container my-4 min-vh-100">
        @RenderBody()
    </div>

    @await Html.PartialAsync("_Footer")
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-4 border-0 shadow-sm mb-4" role="alert">
            <div class="d-flex align-items-center">
                <i class="fa-solid fa-circle-check fs-4 me-3"></i>
                <div>
                    <strong class="d-block">Thành công!</strong>
                    @TempData["SuccessMessage"]
                </div>
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @* <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js"></script>
    <script src="~/lib/flatpickr/flatpickr.min.js"></script>
    <script src="~/lib/flatpickr/l10n/vn.js"></script> *@

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js"></script>

    <script src="~/lib/flatpickr/flatpickr.min.js"></script>
    <script src="~/lib/flatpickr/l10n/vn.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            flatpickr(".date-picker", {
                dateFormat: "d/m/Y",
                locale: "vn",
                allowInput: false
            });
            document.querySelectorAll(".money-input").forEach(element => {
                new AutoNumeric(element, {
                    digitGroupSeparator: '.',
                    decimalCharacter: ',',
                    decimalPlaces: 0,
                    unformatOnSubmit: true
                });
            });
            document.querySelectorAll(".open-modal").forEach(element => {
                 element.addEventListener("click", function (e) {
                    openModal(e, this);
                });
            });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
    
</body>
</html>
