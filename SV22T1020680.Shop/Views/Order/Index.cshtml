@model List<OrderViewInfo>
@{
    ViewData["Title"] = "Lịch sử giao dịch";
    Layout = "_Layout";
}

<div class="container ">
    <div class="card border-0 shadow-sm rounded-4 p-4 mb-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h3 class="fw-bold mb-0 text-primary">
                <i class="fa-solid fa-clock-rotate-left me-2"></i>Lịch sử giao dịch
            </h3>
        </div>

        <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4 py-3 text-uppercase small fw-bold">Mã đơn</th>
                            <th class="py-3 text-uppercase small fw-bold">Ngày đặt</th>
                            <th class="py-3 text-uppercase small fw-bold">Địa chỉ giao hàng</th>
                            <th class="py-3 text-uppercase small fw-bold">Trạng thái</th>
                            <th class="py-3 text-uppercase small fw-bold text-end pe-4">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-primary">#@item.OrderID</td>
                                <td>
                                    <div class="small fw-medium">@item.OrderTime.ToString("dd/MM/yyyy")</div>
                                    <div class="text-muted" style="font-size: 11px;">@item.OrderTime.ToString("HH:mm")</div>
                                </td>
                                <td>
                                    <div class="text-truncate" style="max-width: 250px;">@item.DeliveryAddress</div>
                                    <div class="small text-muted">@item.DeliveryProvince</div>
                                </td>
                                <td>
                                    <span class="badge bg-info-subtle text-info rounded-pill px-3 border border-info">@item.Status.GetDescription()</span>
                                </td>
                                <td class="text-end pe-4">
                                    <a href="/Order/Details/@item.OrderID" class="btn btn-outline-primary btn-sm rounded-pill px-3">
                                        <i class="fa-solid fa-eye me-1"></i>Chi tiết
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    </div>

@section Styles {
    <style>
        .page-link {
            color: #333;
            width: 40px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .page-item.active .page-link {
            background-color: #0d6efd;
            color: white;
        }

        .hover-shadow:hover {
            box-shadow: 0 .5rem 1rem rgba(0,0,0,.15) !important;
            transition: 0.3s;
        }
    </style>
}

