@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>Đăng nhập - LiteCommerce</title>
    <link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/lib/font_awesome/css/all.min.css" rel="stylesheet" />
    <link href="~/css/site.css" rel="stylesheet">

    <style>
        body {
            font-family: 'Inter', sans-serif;
            background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
            padding: 15px; /* Thêm padding cho body để mobile không bị sát mép */
        }

        .login-card {
            width: 100%;
            max-width: 450px; /* Tăng độ rộng để nén chiều cao */
            border: none;
            border-radius: 16px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.08);
            background: #fff;
            overflow: hidden;
        }

        /* HEADER MỚI: Gọn gàng hơn */
        .login-header {
            padding: 25px 20px 15px 20px; /* Giảm padding đứng */
            text-align: center;
            border-bottom: 1px solid #f0f0f0;
        }

            .login-header i {
                font-size: 2rem;
                color: #0d6efd;
                margin-bottom: 5px;
            }

            .login-header h4 {
                color: #0d6efd;
                font-weight: 700;
                letter-spacing: -1px;
                margin-bottom: 0;
            }

            .login-header p {
                color: #6c757d;
                font-size: 0.85rem;
                margin-top: 2px;
                margin-bottom: 0;
            }

        /* CARD BODY: Giảm Padding đứng */
        .card-body-compact {
            padding: 25px 30px; /* Nén padding đứng */
        }

        .form-label-compact {
            font-size: 0.8rem;
            font-weight: 600;
            color: #495057;
            margin-bottom: 3px; /* Sát ô nhập hơn */
        }

        .form-control {
            border-radius: 8px;
            padding: 10px 15px; /* Nén padding ô nhập */
            font-size: 0.95rem;
            border: 1px solid #dee2e6;
            background-color: #fbfcfd;
        }

            .form-control:focus {
                box-shadow: 0 0 0 0.2rem rgba(13, 110, 253, 0.08);
                background-color: #fff;
                border-color: #0d6efd;
            }

        .input-group-text {
            border-radius: 8px;
            background-color: #fff;
            color: #adb5bd;
            border-color: #dee2e6;
        }

        .btn-login {
            border-radius: 8px;
            padding: 11px;
            font-weight: 700;
            font-size: 0.9rem;
            letter-spacing: 0.5px;
            transition: 0.2s;
        }

            .btn-login:hover {
                transform: translateY(-1px);
                box-shadow: 0 4px 10px rgba(13, 110, 253, 0.2);
            }

        .divider-compact {
            color: #adb5bd;
            display: flex;
            align-items: center;
            margin: 15px 0;
            font-size: 0.75rem;
        }

            .divider-compact::before, .divider-compact::after {
                content: "";
                flex: 1;
                height: 1px;
                background: #eee;
                margin: 0 12px;
            }

        .btn-register-outline {
            border-radius: 8px;
            font-size: 0.85rem;
            font-weight: 600;
            color: #6c757d;
            border: 2px solid #dee2e6;
            padding: 9px;
            transition: 0.2s;
        }

            .btn-register-outline:hover {
                background-color: #f8f9fa;
                border-color: #ced4da;
                color: #495057;
            }
    </style>
</head>
<body>

    <div class="login-card">
        <div class="login-header">
            <div class="d-flex align-items-center justify-content-center gap-2 mb-1">
                <i class="fa-solid fa-bolt-lightning fs-3 mb-0"></i>
                <h4 class="mb-0">LITECOMMERCE</h4>
            </div>
            <p>Chào mừng bạn quay lại mua sắm!</p>
        </div>

        <div class="card-body card-body-compact">
            <form action="/Account/Login" method="POST">
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(true, "", new { @class = "text-danger small mb-3 text-center" })

                <div class="mb-2">
                    <label class="form-label form-label-compact">Email đăng nhập</label>
                    <div class="input-group input-group-sm-compact">
                        <span class="input-group-text border-end-0"><i class="fa-regular fa-envelope"></i></span>
                        <input type="email" name="email" class="form-control border-start-0 shadow-none" placeholder="name@company.com" required>
                    </div>
                </div>

                <div class="mb-2">
                    <div class="d-flex justify-content-between align-items-center">
                        <label class="form-label form-label-compact">Mật khẩu</label>
                    </div>
                    <div class="input-group input-group-sm-compact">
                        <span class="input-group-text border-end-0"><i class="fa-solid fa-lock"></i></span>
                        <input type="password" name="password" id="passwordInput" class="form-control border-start-0 shadow-none" placeholder="••••••••" required>
                        <button class="btn btn-outline-light border border-start-0 text-muted px-2" type="button" onclick="togglePassword()">
                            <i class="fa-regular fa-eye-slash" id="toggleIcon" style="font-size: 0.8rem;"></i>
                        </button>
                    </div>
                </div>

                <button type="submit" class="btn btn-primary w-100 btn-login mb-2">
                    ĐĂNG NHẬP NGAY
                </button>

                <div class="divider-compact small text-uppercase fw-bold">Hoặc</div>

                <div class="text-center">
                    <p class="small text-muted mb-1" style="font-size: 0.75rem;">Chưa có tài khoản?</p>
                    <a href="/Customer/Create" class="btn btn-register-outline w-100 py-2">
                        TẠO TÀI KHOẢN MỚI
                    </a>
                </div>
            </form>
        </div>
    </div>

    <script>
        function togglePassword() {
            const passwordInput = document.getElementById('passwordInput');
            const toggleIcon = document.getElementById('toggleIcon');
            if (passwordInput.type === 'password') {
                passwordInput.type = 'text';
                toggleIcon.classList.replace('fa-eye-slash', 'fa-eye');
            } else {
                passwordInput.type = 'password';
                toggleIcon.classList.replace('fa-eye', 'fa-eye-slash');
            }
        }
    </script>
</body>
</html>