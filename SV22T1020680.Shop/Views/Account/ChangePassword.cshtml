@{
    ViewData["Title"] = "Bảo mật tài khoản";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-6 col-xl-5">

            <div class="card border-0 shadow-lg position-relative overflow-hidden" style="border-radius: 20px;">
                <div class="position-absolute top-0 start-0 w-100" style="height: 6px; background: linear-gradient(90deg, #0d6efd, #0dcaf0);"></div>

                <div class="card-body p-4 p-md-5">
                    <div class="text-center mb-4 mt-2">
                        <div class="security-icon mb-3 mx-auto shadow-sm">
                            <i class="fa-solid fa-user-shield text-primary"></i>
                        </div>
                        <h3 class="fw-bold text-dark">Bảo mật tài khoản</h3>
                        @Html.ValidationMessage("Error", null, new { @class = "text-danger small mt-2" })
                        <p class="text-muted small px-lg-4">Vui lòng nhập mật khẩu hiện tại và mật khẩu mới để bảo vệ an toàn cho tài khoản của bạn.</p>
                    </div>

                    <form action="/Account/ConfirmChangePassword" method="POST" id="changePassForm">
                        @Html.AntiForgeryToken()

                        <div class="form-floating mb-3">
                            <input type="password" name="oldPassword" class="form-control custom-input" id="oldPass" placeholder="Password" required>
                            <label for="oldPass" class="text-muted">
                                <i class="fa-solid fa-key me-2 text-primary opacity-75"></i>Mật khẩu hiện tại
                            </label>
                        </div>

                        <hr class="my-4 opacity-10">

                        <div class="mb-3">
                            <label class="form-label small fw-bold text-dark-emphasis">Mật khẩu mới</label>
                            <div class="input-group">
                                <span class="input-group-text bg-white border-end-0 text-muted shadow-none custom-addon"><i class="fa-solid fa-lock"></i></span>
                                <input type="password" name="newPassword" id="newPass" class="form-control border-start-0 shadow-none custom-control" placeholder="Tối thiểu 6 ký tự" required>
                                <button class="btn btn-outline-light border border-start-0 text-muted shadow-none px-3 custom-control" type="button" onclick="togglePass('newPass', 'newPassIcon')">
                                    <i class="fa-regular fa-eye-slash" id="newPassIcon"></i>
                                </button>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label small fw-bold text-dark-emphasis">Xác nhận mật khẩu mới</label>
                            <div class="input-group">
                                <span class="input-group-text bg-white border-end-0 text-muted shadow-none custom-addon"><i class="fa-solid fa-check-double"></i></span>
                                <input type="password" name="confirmPassword" id="confirmPass" class="form-control border-start-0 shadow-none custom-control" placeholder="Nhập lại mật khẩu mới" required>
                                <button class="btn btn-outline-light border border-start-0 text-muted shadow-none px-3 custom-control" type="button" onclick="togglePass('confirmPass', 'confirmPassIcon')">
                                    <i class="fa-regular fa-eye-slash" id="confirmPassIcon"></i>
                                </button>
                            </div>
                        </div>

                        <div class="d-grid gap-2 mt-2">
                            <button type="submit" class="btn btn-primary py-2 fw-bold shadow-sm" style="border-radius: 12px; font-size: 1rem; transition: 0.3s;">
                                <i class="fa-solid fa-shield-halved me-2"></i>CẬP NHẬT MẬT KHẨU
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        /* Tối ưu hóa giao diện dựa trên code của Nghĩa */
        .security-icon {
            width: 75px;
            height: 75px;
            border-radius: 50%;
            background-color: rgba(13, 110, 253, 0.08);
            display: flex;
            align-items: center;
            justify-content: center;
        }

            .security-icon i {
                font-size: 2.2rem;
            }

        .form-floating > label {
            padding-left: 1.2rem;
        }

        .custom-input {
            border-radius: 12px;
            border: 1px solid #e9ecef;
            background-color: #f8f9fa;
            transition: all 0.2s ease-in-out;
        }

            .custom-input:focus {
                background-color: #fff;
                border-color: #0d6efd;
                box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.1);
            }

        .custom-addon {
            border-radius: 12px 0 0 12px;
            border: 1px solid #e9ecef;
        }

        .custom-control {
            border-radius: 12px;
            border: 1px solid #e9ecef;
        }

        /* Hiệu ứng khi rê chuột vào nút bấm */
        .btn-primary:hover {
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(13, 110, 253, 0.2) !important;
        }
    </style>
}

@section Scripts {
    <script>
        function togglePass(inputId, iconId) {
            const input = document.getElementById(inputId);
            const icon = document.getElementById(iconId);
            const isPassword = input.type === 'password';
            input.type = isPassword ? 'text' : 'password';
            icon.classList.toggle('fa-eye-slash', !isPassword);
            icon.classList.toggle('fa-eye', isPassword);
        }
    </script>
}