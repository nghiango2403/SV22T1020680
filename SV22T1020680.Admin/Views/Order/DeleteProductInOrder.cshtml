@model OrderDetailViewInfo
@{
    Layout = null;
}
<div class="modal-header text-bg-danger">
    <strong class="modal-title">
        Xóa mặt hàng khỏi đơn hàng
    </strong>
    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
</div>
@Html.ValidationMessage("Error", null, new { @class = "text-danger" })
<div class="modal-body">
    <div class="alert alert-danger">
        <i class="bi bi-info-circle me-2"></i>
        Bạn có muốn xóa mặt hàng <strong>@Model.ProductName</strong> ra khỏi đơn hàng không?
    </div>
</div>

<div class="modal-footer">
    <form action="~/Order/DeleteProductInOrder" method="post">
        <input type="hidden" name="id" value="@ViewBag.OrderID" />
        <input type="hidden" name="productId" value="@Model.ProductID" />
        <button type="submit" class="btn btn-primary" data-bs-dismiss="modal">
            <i class="bi bi-check"></i> Chấp nhận
        </button>
    </form>
        
    <button type="button"
            class="btn btn-secondary"
            data-bs-dismiss="modal">
        Đóng
    </button>
</div>
