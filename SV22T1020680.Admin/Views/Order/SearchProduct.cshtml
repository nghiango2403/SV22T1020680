@model PagedResult<Product>
@{
    Layout = null;
}
@foreach (var item in Model.DataItems)
{
    <form method="post" class="border rounded p-2 mb-2" onsubmit="addCartItem(event, this)">
        <strong>@item.ProductName</strong>
        <input type="hidden" name="productId" value="@item.ProductID" />
        <div class="row mt-2">
            <div class="col-4">
                <img src="~/images/products/@item.Photo"
                     class="img-fluid border" style="max-height:100px" />
            </div>
            <div class="col-8">
                <div class="row g-2">
                    <div class="col-7">
                        <label class="form-label mb-0">Giá</label>
                        <input class="form-control form-control-sm money-input"
                                name="price"
                               value="@item.Price" />
                    </div>
                    <div class="col-5">
                        <label class="form-label mb-0">SL</label>
                        <input type="number"
                               min="1"
                               value="1"
                               name="quantity"
                               class="form-control form-control-sm" />
                    </div>
                </div>

                <button class="btn btn-sm btn-primary mt-2 w-100">
                    <i class="bi bi-cart-plus"></i>
                    Thêm vào giỏ
                </button>
            </div>
        </div>
    </form>
}
<div class="card-footer">
    <ul class="pagination justify-content-between mb-0">
        @{
            // Sửa CurrentPage thành Page, và TotalPages thành PageCount (hoặc tên tương ứng trong Model của bạn)
            var currentPage = Model.Page;
            var hasPrevious = currentPage > 1;
            var hasNext = currentPage < Model.PageCount;
        }

        <li class="page-item @(hasPrevious ? "" : "disabled")">
            <a class="page-link"
               href="javascript:void(0);"
               @(hasPrevious? Html.Raw($"onclick=\"paginationSearch(event, document.getElementById('formSearch'), {currentPage - 1});\"") : "")>
                <i class="bi bi-chevron-left"></i>
            </a>
        </li>

        <li class="page-item @(hasNext ? "" : "disabled")">
            <a class="page-link"
               href="javascript:void(0);"
               @(hasNext? Html.Raw($"onclick=\"paginationSearch(event, document.getElementById('formSearch'), {currentPage + 1});\"") : "")>
                <i class="bi bi-chevron-right"></i>
            </a>
        </li>
    </ul>
</div>