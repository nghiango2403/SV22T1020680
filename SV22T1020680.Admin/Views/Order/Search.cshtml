@model PagedResult<OrderViewInfo>
@{
    Layout = null;
}
<div class="mb-2 text-muted">
    Danh sách này có <strong>@Model.RowCount</strong> đơn hàng
</div>

<div class="card">
    <div class="card-body p-1">
        <table class="table table-bordered table-hover mb-0 align-middle">
            <thead class="table-secondary">
                <tr>
                    <th>Ngày đặt hàng</th>
                    <th>Tên khách hàng</th>
                    <th>Điện thoại</th>
                    <th>Ngày duyệt</th>
                    <th>Nhân viên xử lý</th>
                    <th class="text-end">Tổng tiền</th>
                    <th class="text-center" style="width:140px;">Trạng thái</th>
                    <th class="text-center" style="width:40px"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.DataItems)
                {
                    <tr>
                        <td>@item.OrderTime</td>
                        <td>@item.CustomerName</td>
                        <td>@item.CustomerPhone</td>
                        <td>@item.FinishedTime</td>
                        <td>@item.EmployeeName</td>
                        <td class="text-end">1,250,000</td>
                        <td class="text-center">
                            @{
                                var status = item.Status;

                                string badgeClass = status switch
                                {
                                    OrderStatusEnum.New => "bg-warning text-dark",
                                    OrderStatusEnum.Accepted => "bg-info text-dark",
                                    OrderStatusEnum.Shipping => "bg-primary",
                                    OrderStatusEnum.Completed => "bg-success",
                                    OrderStatusEnum.Cancelled => "bg-danger",
                                    OrderStatusEnum.Rejected => "bg-dark",
                                    _ => "bg-secondary"
                                };

                                string statusName = status switch
                                {
                                    OrderStatusEnum.New => "Đang chờ duyệt",
                                    OrderStatusEnum.Accepted => "Đã duyệt",
                                    OrderStatusEnum.Shipping => "Đang giao",
                                    OrderStatusEnum.Completed => "Hoàn tất",
                                    OrderStatusEnum.Cancelled => "Bị hủy",
                                    OrderStatusEnum.Rejected => "Bị từ chối",
                                    _ => "Không xác định"
                                };
                            }
                            <span class="badge @badgeClass">@statusName</span>
                        </td>
                        <td class="text-center text-nowrap">
                            <a href="~/Order/Detail/@item.OrderID" class="btn btn-sm btn-primary">
                                <i class="bi bi-receipt"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="card-footer">
        <!-- Pagination -->
        <ul class="pagination justify-content-center">
            @foreach (var pageItem in Model.GetDisplayPages())
            {
                if (pageItem.IsCurrent)
                {
                    <li class="page-item active">
                        <span class="page-link">@pageItem.Page</span>
                    </li>
                }
                else if (pageItem.IsEllipsis)
                {
                    <li class="page-item disabled">
                        <span class="page-link">...</span>
                    </li>
                }
                else
                {
                    <li class="page-item">
                        <a class="page-link"
                           href="javascript:void(0);"
                           onclick="paginationSearch(event, document.getElementById('formSearch'), @pageItem.Page);">
                            @pageItem.Page
                        </a>
                    </li>
                }
            }
        </ul>
    </div>
</div>
