@model PagedResult<Product>
@{
    Layout = null;
}
<div class="mb-2 text-muted">
    Danh sách này có <strong>@Model.RowCount</strong> mặt hàng
</div>

<div class="card">
    <div class="card-body p-1">
        <table class="table table-bordered table-hover mb-0 align-middle">
            <thead class="table-secondary">
                <tr>
                    <th style="width:80px;">Ảnh</th>
                    <th>Mặt hàng</th>
                    <th style="width:120px;">Đơn vị</th>
                    <th style="width:120px;">Giá</th>
                    <th class="text-center" style="width:140px;">Trạng thái</th>
                    <th class="text-center" style="width:100px;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.DataItems)
                {
                    <tr>
                        <td class="text-center">
                            <img src="~/images/products/@item.Photo"
                                 class="img-thumbnail"
                                 alt="Ảnh mặt hàng" />
                        </td>
                        <td>
                            <strong>@item.ProductName</strong><br />
                            <small class="text-muted">
                                @item.ProductDescription
                            </small>
                        </td>
                        <td>@item.Unit</td>
                        <td class="text-end">@item.Price.ToString("#,##0")</td>
                        <td class="text-center">
                            @if (item.IsSelling)
                            {
                                <span class="badge bg-success">Đang bán</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Ngừng bán</span>
                            }

                        </td>
                        <td class="text-center text-nowrap">
                            <a href="~/Product/Edit/@item.ProductID" class="btn btn-sm btn-primary">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <a href="~/Product/Delete/@item.ProductID" class="btn btn-sm btn-danger">
                                <i class="bi bi-trash"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="card-footer">
        <!-- Pagination -->
        <ul class="pagination justify-content-center">
            @foreach (var pageItem in Model.GetDisplayPages())
            {
                if (pageItem.IsCurrent)
                {
                    <li class="page-item active">
                        <span class="page-link">@pageItem.Page</span>
                    </li>
                }
                else if (pageItem.IsEllipsis)
                {
                    <li class="page-item disabled">
                        <span class="page-link">...</span>
                    </li>
                }
                else
                {
                    <li class="page-item">
                        <a class="page-link"
                           href="javascript:void(0);"
                           onclick="paginationSearch(event, document.getElementById('formSearch'), @pageItem.Page);">
                            @pageItem.Page
                        </a>
                    </li>
                }
            }
        </ul>
    </div>
</div>