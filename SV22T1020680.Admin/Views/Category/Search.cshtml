@model PagedResult<Category>
@{
    Layout = null;
}
<div class="mb-2 text-muted">
    Danh sách này có <strong>8</strong> loại hàng
</div>

<div class="card">
    <div class="card-body p-1">
        <table class="table table-bordered table-hover mb-0">
            <thead class="table-secondary">
                <tr>
                    <th>Tên loại hàng</th>
                    <th>Mô tả</th>
                    <th class="text-center" style="width:100px;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.DataItems)
                {
                    <tr>
                        <td>@item.CategoryName</td>
                        <td>@item.Description</td>
                        <td class="text-center text-nowrap">
                            <a href="~/Category/Edit/@item.CategoryID" class="btn btn-sm btn-primary">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <a href="~/Category/Delete/@item.CategoryID" class="btn btn-sm btn-danger">
                                <i class="bi bi-trash"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="card-footer">
        <!-- Pagination -->
        <ul class="pagination justify-content-center">
            @foreach (var pageItem in Model.GetDisplayPages())
            {
                if (pageItem.IsCurrent)
                {
                    <li class="page-item active">
                        <span class="page-link">@pageItem.Page</span>
                    </li>
                }
                else if (pageItem.IsEllipsis)
                {
                    <li class="page-item disabled">
                        <span class="page-link">...</span>
                    </li>
                }
                else
                {
                    <li class="page-item">
                        <a class="page-link"
                           href="javascript:void(0);"
                           onclick="paginationSearch(event, document.getElementById('formSearch'), @pageItem.Page);">
                            @pageItem.Page
                        </a>
                    </li>
                }
            }
        </ul>
    </div>
</div>
